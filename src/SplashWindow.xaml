<Window x:Class="NativeMDView.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="360" Height="180">
    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#3E3E42" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="MDView" FontSize="32" FontWeight="Bold" 
                       Foreground="#569CD6" HorizontalAlignment="Center"
                       FontFamily="Segoe UI"/>
            <TextBlock Text="Loading Markdown Editor..." FontSize="12" 
                       Foreground="#9CDCFE" HorizontalAlignment="Center" 
                       Margin="0,8,0,0" Opacity="0.8"
                       FontFamily="Segoe UI"/>
            <ProgressBar IsIndeterminate="True" Width="240" Height="3" 
                         Margin="0,20,0,0" 
                         Foreground="#569CD6" Background="#2D2D30"
                         BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>
