<Window x:Class="NativeMDView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MDView - Markdown Editor" 
        Height="700" Width="1000"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}">
    
    <Window.Resources>
        <SolidColorBrush x:Key="DarkWindowBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DarkWindowForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="DarkEditorBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DarkEditorForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="DarkToolbarBackground" Color="#252526"/>
        <SolidColorBrush x:Key="DarkStatusBarBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="DarkStatusBarForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="DarkSeparator" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DarkButtonHover" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DarkButtonPressed" Color="#094771"/>
        <SolidColorBrush x:Key="DarkMenuPopupBackground" Color="#252526"/>
        <SolidColorBrush x:Key="DarkMenuPopupBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DarkMenuHover" Color="#094771"/>
        
        <SolidColorBrush x:Key="LightWindowBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightWindowForeground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="LightEditorBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightEditorForeground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="LightToolbarBackground" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="LightStatusBarBackground" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="LightStatusBarForeground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="LightSeparator" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="LightButtonHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="LightButtonPressed" Color="#C9DEF5"/>
        <SolidColorBrush x:Key="LightMenuPopupBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightMenuPopupBorder" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="LightMenuHover" Color="#C9DEF5"/>
        
        <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="WindowForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="EditorBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="EditorForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="ToolbarBackground" Color="#252526"/>
        <SolidColorBrush x:Key="StatusBarBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="StatusBarForeground" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#3E3E42"/>
        <SolidColorBrush x:Key="ButtonPressed" Color="#094771"/>
        <SolidColorBrush x:Key="MenuPopupBackground" Color="#252526"/>
        <SolidColorBrush x:Key="MenuPopupBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="MenuHover" Color="#094771"/>
        
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource EditorForeground}"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource MenuPopupBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
            <Setter Property="Padding" Value="20,5,20,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                    <ColumnDefinition Width="13"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon" Margin="0,0,10,0"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="20,0,0,0" Foreground="{TemplateBinding Foreground}" Opacity="0.7"/>
                                <Path Grid.Column="3" x:Name="Arrow" Data="M0,0 L4,3.5 L0,7 Z" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Popup x:Name="Popup" Placement="Right" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource MenuPopupBackground}" BorderBrush="{DynamicResource MenuPopupBorder}" BorderThickness="1" Padding="2">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuHover}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Menu Grid.Row="0" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource WindowForeground}" FontSize="13" ItemContainerStyle="{StaticResource MenuItemStyle}">
            <MenuItem Header="_File">
                <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="NewFile_Click"/>
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="OpenFile_Click"/>
                <Separator/>
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="SaveFile_Click"/>
                <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAsFile_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click"/>
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click"/>
                <Separator/>
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="Cut_Click"/>
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="Copy_Click"/>
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="Paste_Click"/>
                <Separator/>
                <MenuItem Header="_Select All" InputGestureText="Ctrl+A" Click="SelectAll_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Preview Only" Click="ShowPreviewOnly_Click"/>
                <MenuItem Header="_Editor Only" Click="ShowEditorOnly_Click"/>
                <MenuItem Header="_Split View" Click="ShowSplitView_Click"/>
                <Separator/>
                <MenuItem Header="_Toggle Toolbar" Click="ToggleToolbar_Click"/>
                <Separator/>
                <MenuItem Header="Toggle _Theme" Click="ToggleTheme_Click"/>
                <Separator/>
                <MenuItem Header="Zoom _In" InputGestureText="Ctrl++" Click="ZoomIn_Click"/>
                <MenuItem Header="Zoom _Out" InputGestureText="Ctrl+-" Click="ZoomOut_Click"/>
                <MenuItem Header="_Reset Zoom" InputGestureText="Ctrl+0" Click="ResetZoom_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>
        
        <WrapPanel Grid.Row="1" x:Name="ToolbarPanel" Background="{DynamicResource ToolbarBackground}" Visibility="Visible">
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Bold_Click" ToolTip="Bold (Ctrl+B)">
                <TextBlock FontWeight="Bold">B</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Italic_Click" ToolTip="Italic (Ctrl+I)">
                <TextBlock FontStyle="Italic">I</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="StrikeThrough_Click" ToolTip="Strikethrough">
                <TextBlock TextDecorations="Strikethrough">S</TextBlock>
            </Button>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="5,4"/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="H1_Click" ToolTip="Heading 1">
                <TextBlock FontWeight="Bold">H1</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="H2_Click" ToolTip="Heading 2">
                <TextBlock FontWeight="Bold">H2</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="H3_Click" ToolTip="Heading 3">
                <TextBlock FontWeight="Bold">H3</TextBlock>
            </Button>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="5,4"/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="BulletList_Click" ToolTip="Bullet List">
                <TextBlock>• List</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="NumberedList_Click" ToolTip="Numbered List">
                <TextBlock>1. List</TextBlock>
            </Button>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="5,4"/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="CodeBlock_Click" ToolTip="Code Block">
                <TextBlock FontFamily="Consolas">&lt;/&gt;</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="InlineCode_Click" ToolTip="Inline Code">
                <TextBlock FontFamily="Consolas">`code`</TextBlock>
            </Button>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="5,4"/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Quote_Click" ToolTip="Quote">
                <TextBlock>"Quote"</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Link_Click" ToolTip="Link (Ctrl+K)">
                <TextBlock>Link</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Image_Click" ToolTip="Image">
                <TextBlock>Image</TextBlock>
            </Button>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="5,4"/>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Table_Click" ToolTip="Insert Table">
                <TextBlock>Table</TextBlock>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="HorizontalRule_Click" ToolTip="Horizontal Rule">
                <TextBlock>―</TextBlock>
            </Button>
        </WrapPanel>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="0"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="Editor" 
                     Grid.Column="0"
                     Style="{StaticResource EditorTextBoxStyle}"
                     TextChanged="Editor_TextChanged"
                     SelectionChanged="Editor_SelectionChanged"
                     Visibility="Collapsed"
                     IsReadOnly="False"/>
            
            <ScrollViewer x:Name="PreviewScroll" Grid.Column="1" Visibility="Visible" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel x:Name="PreviewPanel" Margin="32,24"/>
            </ScrollViewer>
        </Grid>
        
        <StatusBar Grid.Row="3" Background="{DynamicResource StatusBarBackground}" Foreground="{DynamicResource StatusBarForeground}" Height="25">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusFile" Text="New File" Margin="5,0"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="2">
                <TextBlock x:Name="StatusCursor" Text="Ln 1, Col 1" Margin="10,0"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="StatusWords" Text="0 words" Margin="10,0"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="4">
                <TextBlock x:Name="StatusZoom" Text="100%" Margin="10,0"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="5">
                <TextBlock x:Name="StatusMode" Text="Ctrl+E Edit" Margin="10,0" Opacity="0.7"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
